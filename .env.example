# Telegram bot token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin user Telegram ID
ADMIN_ID=123456789

# Channel IDs (negative numbers for supergroups/channels)
CS_STG3=-1001234567890
CS_STG3_ONEFILE=-1001234567890
CS_STG3_DELETED=-1001234567890
CS_APPS=-1001234567890
LOG_CHANNEL_ID=-1001234567890

# Optional Telegram proxy URL.
# Leave empty for a direct connection to Telegram.
# Uncomment and set only if using Tor or another SOCKS proxy:
# TELEGRAM_PROXY_URL=socks5h://127.0.0.1:9050
